# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# Get a key from the dashboard, or run `vercel env pull .env.local` after
# enabling AI Gateway on the linked project (provisions VERCEL_OIDC_TOKEN
# instead, which the SDK also accepts).
AI_GATEWAY_API_KEY=

# Google Calendar (booking tool, consumed by the Python backend via
# backend/calendar_lib.py) — see scripts/get-google-refresh-token.ts
# for how to get GOOGLE_REFRESH_TOKEN. GOOGLE_CLIENT_ID/SECRET come from an
# OAuth client (type "Desktop app") in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google GenAI (Python backend) — get a key from Google AI Studio. Used for
# Gemini chat generation and text-embedding-004 (resume_search, mphil_research,
# and the scripts/build_*_corpus.py generators). Distinct from the Calendar
# OAuth creds above. Loaded via python-dotenv from this same .env.local.
GOOGLE_API_KEY=

# Where the calendar invite's owner slot goes (Google Calendar emails the
# invite to this address automatically via sendUpdates=all).
OWNER_EMAIL=andrews.trinh@gmail.com

# GitHub (git_hub_query tool) — raises the unauthenticated 60 req/hr rate
# limit; a fine-grained PAT with only public-repo read access is enough.
GITHUB_TOKEN=

# Neon Postgres (rate limiting) — for local dev, set NEON_CONNECTION_STRING to a
# connection string from the Neon console. In production, install via the Vercel
# Marketplace (`vercel integration add neon`), which auto-provisions DATABASE_URL
# instead — both are read (see src/lib/ratelimit.ts), so either works.
# Run scripts/init-neon-schema.sql once against the database before first use.
# Without either set, rate limiting is a no-op.
NEON_CONNECTION_STRING=


# Optional: HMAC-signs booking tool-approval requests so a client can't
# forge an approval for a booking it never saw. Generate with:
#   openssl rand -base64 32
TOOL_APPROVAL_SECRET=
