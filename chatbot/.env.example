# Vercel AI Gateway — https://vercel.com/docs/ai-gateway
# Get a key from the dashboard, or run `vercel env pull .env.local` after
# enabling AI Gateway on the linked project (provisions VERCEL_OIDC_TOKEN
# instead, which the SDK also accepts).
AI_GATEWAY_API_KEY=

# Google Calendar (booking tool) — see scripts/get-google-refresh-token.ts
# for how to get GOOGLE_REFRESH_TOKEN. GOOGLE_CLIENT_ID/SECRET come from an
# OAuth client (type "Desktop app") in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Resend (booking notification email) — https://resend.com/api-keys
RESEND_API_KEY=
# Must be on a domain verified in Resend. Falls back to the Resend sandbox
# sender (onboarding@resend.dev) if unset, which only delivers to your own
# Resend account email.
RESEND_FROM=
# Where booking notifications and the calendar invite's owner slot go.
OWNER_EMAIL=andrews.trinh@gmail.com

# GitHub (git_hub_query tool) — raises the unauthenticated 60 req/hr rate
# limit; a fine-grained PAT with only public-repo read access is enough.
GITHUB_TOKEN=

# Upstash Redis (rate limiting) — install via the Vercel Marketplace
# (`vercel integration add upstash`), which provisions these automatically.
# Without them, rate limiting is a no-op (see src/lib/ratelimit.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: HMAC-signs booking tool-approval requests so a client can't
# forge an approval for a booking it never saw. Generate with:
#   openssl rand -base64 32
TOOL_APPROVAL_SECRET=
